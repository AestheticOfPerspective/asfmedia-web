---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const stack = [
  { lang: 'Python', level: 'Aktiv lernend', note: 'Hauptsprache 2026 — Skripte, Bots, APIs, Automatisierung.' },
  { lang: 'Bash / Shell', level: 'Täglich', note: 'System-Management, Automatisierung, Docker-Workflows.' },
  { lang: 'Astro / HTML / CSS', level: 'Produktiv', note: 'Static Sites, Komponenten, responsive Layouts.' },
  { lang: 'JavaScript', level: 'Grundlagen', note: 'Client-side Logik, DOM, Event Handling.' },
];

const projects = [
  {
    name: 'DJ Agent Bot',
    tags: ['Python', 'Telegram', 'Subsonic API'],
    text: 'Telegram Bot für kuratierte Navidrome-Playlists via /vibe. Baut Playlists dynamisch aus dem eigenen Music Server.',
    status: 'In Entwicklung',
  },
  {
    name: 'ASFMedia Site',
    tags: ['Astro', 'TypeScript', 'GitHub Pages'],
    text: 'Diese Seite — gebaut mit Astro, deployed auf GitHub Pages mit Custom Domain.',
    status: 'Live',
  },
  {
    name: 'Agent Network Scripts',
    tags: ['Bash', 'Python', 'Claude Code'],
    text: 'Automatisierungsscripts für das Agent Network: Status, Logs, Handoffs und Sync.',
    status: 'Laufend',
  },
];

const tools = [
  'Claude Code (AI-assisted Development)',
  'Ollama (lokale LLMs)',
  'GitHub Copilot',
  'Docker + Compose',
  'VS Code',
  'Git + GitHub',
];

const goals = [
  { quarter: 'Q2 2026', goal: 'Python Grundlagen solide: OOP, APIs, Fehlerhandling, Tests.' },
  { quarter: 'Q3 2026', goal: 'DJ Bot produktionsreif + eigene Telegram Bot Library.' },
  { quarter: 'Q4 2026', goal: 'Datenanalyse Basics: pandas, Visualisierung, CSV-Workflows.' },
  { quarter: '2027', goal: 'Eigenständige API-Produkte und erste Open Source Contributions.' },
];
---

<Layout
  title="Dev Journey"
  description="Fossnomades Python Lernreise — Stack, Projekte, Tools und Ziele für 2026."
>
  <Nav />

  <main class="page-shell">
    <section class="section-tight">
      <div class="container">
        <p class="eyebrow">Dev Journey · 2026</p>
        <h1 class="display-title">Python lernen. Bots bauen. Dinge automatisieren.</h1>
        <p class="section-lead">
          Keine Uni, kein Bootcamp — learning by doing mit echten Projekten,
          AI-Tools als Co-Pilot und dem Ziel, jeden Tag ein bisschen mehr zu können.
        </p>
      </div>
    </section>

    <section class="section section-stripe">
      <div class="container split-grid">
        <div>
          <p class="eyebrow">Stack</p>
          <h2 class="section-title">Was ich gerade nutze und lerne.</h2>
          <div class="stack-list">
            {stack.map((s) => (
              <article class="card stack-card">
                <div class="stack-head">
                  <h3>{s.lang}</h3>
                  <span class="chip">{s.level}</span>
                </div>
                <p>{s.note}</p>
              </article>
            ))}
          </div>
        </div>

        <div>
          <p class="eyebrow">Toolchain</p>
          <h2 class="section-title">Die täglichen Tools.</h2>
          <article class="panel tools-panel">
            <ul class="list-clean tools-list">
              {tools.map((t) => <li>{t}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <p class="eyebrow">Projekte</p>
        <h2 class="section-title">Was ich gerade baue.</h2>
        <div class="projects-grid">
          {projects.map((p) => (
            <article class="card project-card">
              <div class="project-head">
                <h3>{p.name}</h3>
                <span class:list={[
                  'status-pill',
                  p.status === 'Live' && 'status-live',
                  p.status === 'In Entwicklung' && 'status-dev',
                ]}>
                  {p.status}
                </span>
              </div>
              <div class="tag-row">
                {p.tags.map((tag) => <span class="chip">{tag}</span>)}
              </div>
              <p>{p.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-stripe">
      <div class="container">
        <p class="eyebrow">Roadmap</p>
        <h2 class="section-title">Wohin die Reise geht.</h2>
        <div class="goals-grid">
          {goals.map((g) => (
            <article class="card goal-card">
              <span class="chip">{g.quarter}</span>
              <p>{g.goal}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.section-stripe {
  background: rgba(30, 232, 208, 0.02);
  border-top: 1px solid rgba(30, 232, 208, 0.07);
  border-bottom: 1px solid rgba(30, 232, 208, 0.07);
}

.split-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 2rem;
  align-items: start;
}

.stack-list {
  display: grid;
  gap: 0.8rem;
  margin-top: 1.2rem;
}

.stack-card {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.stack-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.8rem;
}

.stack-head h3 {
  color: var(--ink);
  font-size: 1rem;
}

.stack-card p { font-size: 0.92rem; }

.tools-panel {
  padding: 1.4rem;
  margin-top: 1.2rem;
}

.tools-list { display: grid; gap: 0.55rem; }
.tools-list li { font-size: 0.93rem; }

.projects-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 1.35rem;
}

.project-card {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.project-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.6rem;
}

.project-head h3 {
  color: var(--ink);
  font-size: 1.05rem;
}

.status-pill {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.22rem 0.5rem;
  border-radius: 999px;
  border: 1px solid var(--cyan-border);
  color: var(--ink-muted);
  white-space: nowrap;
  flex-shrink: 0;
}

.status-live {
  color: var(--success);
  border-color: rgba(34, 197, 94, 0.3);
  background: rgba(34, 197, 94, 0.08);
}

.status-dev {
  color: var(--cyan);
  border-color: var(--cyan-border);
  background: var(--cyan-dim);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.project-card p { font-size: 0.92rem; flex: 1; }

.goals-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 1.35rem;
}

.goal-card {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.goal-card p { font-size: 0.93rem; }

@media (max-width: 1020px) {
  .projects-grid,
  .goals-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}

@media (max-width: 800px) {
  .split-grid { grid-template-columns: 1fr; }
  .projects-grid,
  .goals-grid { grid-template-columns: 1fr; }
}
</style>
