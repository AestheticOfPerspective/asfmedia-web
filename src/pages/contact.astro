---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const contactOptions = [
  {
    label: 'Projekt-Mail',
    value: 'hello@asfmedia.org',
    note: 'Fuer Kooperationen, Build-Sprints und kreative Anfragen.',
    href: 'mailto:hello@asfmedia.org?subject=ASFMedia%20Projektanfrage',
  },
  {
    label: 'Telegram',
    value: '@fossnomade',
    note: 'Kurze Abstimmungen und asynchrone Sprint-Kommunikation.',
    href: 'https://t.me/fossnomade',
  },
  {
    label: 'Discovery Call',
    value: '30 Minuten Briefing',
    note: 'Kickoff fuer Scope, Ziel und erstes Konzept.',
    href: 'mailto:hello@asfmedia.org?subject=ASFMedia%20Discovery%20Call',
  },
];

const prep = [
  'Was soll entstehen — Illustration, Site, Bot, Video oder Beratung?',
  'Gibt es ein konkretes Ziel oder eine Deadline?',
  'Welches Budget oder welcher Rahmen steht zur Verfuegung?',
];
---

<Layout
  title="Kontakt"
  description="Kontakt zu ASFMedia — Creative Direction, Illustration, Video, Tech und Consulting. Fossnomade, Nuernberger Land."
>
  <Nav />

  <main class="page-shell" id="early-access">
    <section class="section-tight">
      <div class="container">
        <p class="eyebrow">Kontakt & Early Access</p>
        <h1 class="display-title">Lass uns was Solides bauen.</h1>
        <p class="section-lead">
          Illustration, Site, Bot, Video oder Strategie — schreib mir was du brauchst
          und wir finden den schnellsten Weg zum Ergebnis.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container contact-grid">
        <div class="contact-cards">
          {contactOptions.map((option) => (
            <article class="card option-card">
              <span class="chip">Kontakt</span>
              <h2>{option.label}</h2>
              <a href={option.href} target="_blank" rel="noopener">{option.value}</a>
              <p>{option.note}</p>
            </article>
          ))}
        </div>

        <aside class="panel contact-panel">
          <p class="eyebrow">Schnellanfrage</p>
          <h2>Schick mir direkt was du brauchst.</h2>
          <form action="https://formsubmit.co/hello@asfmedia.org" method="POST">
            <input type="hidden" name="_subject" value="Neue ASFMedia Anfrage" />
            <input type="hidden" name="_next" value="https://web.asfmedia.org/contact?sent=1" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <input class="hp-field" type="text" name="_honey" tabindex="-1" autocomplete="off" />

            <label for="name">Name</label>
            <input id="name" type="text" name="name" placeholder="Dein Name" required />

            <label for="email">E-Mail</label>
            <input id="email" type="email" name="email" placeholder="du@beispiel.de" required />

            <label for="subject">Betreff</label>
            <input id="subject" type="text" name="subject" placeholder="z. B. Modul 02 Build" required />

            <label for="body">Nachricht</label>
            <textarea
              id="body"
              name="message"
              rows="6"
              placeholder="Was soll als naechstes live gehen?"
              required
            ></textarea>

            <button class="btn btn-primary" type="submit">Anfrage senden</button>
          </form>
          <p class="form-note">
            Nach dem Senden wirst du direkt auf die Kontaktseite zurueckgeleitet.
          </p>
        </aside>
      </div>
    </section>

    <section class="section strip">
      <div class="container prep-wrap">
        <p class="eyebrow">Kickoff Vorbereitung</p>
        <h2 class="section-title">Wenn du diese drei Fragen im Kopf hast, wird der Start deutlich schneller.</h2>
        <ul class="list-clean prep-list">
          {prep.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.contact-grid {
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  gap: 1rem;
}

.contact-cards {
  display: grid;
  gap: 0.9rem;
}

.option-card h2 {
  margin: 0.65rem 0 0.3rem;
  color: var(--ink);
  font-size: 1.2rem;
}

.option-card a {
  font-weight: 700;
}

.option-card p {
  margin-top: 0.6rem;
  font-size: 0.92rem;
}

.contact-panel {
  padding: 1.4rem;
}

.contact-panel h2 {
  margin: 0.65rem 0 1rem;
  font-size: clamp(1.4rem, 2.8vw, 2.2rem);
  color: var(--ink);
}

form {
  display: grid;
  gap: 0.68rem;
}

label {
  font-family: var(--font-mono);
  font-size: 0.73rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

input,
textarea {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: rgba(255, 250, 243, 0.9);
  color: var(--ink);
  padding: 0.78rem 0.9rem;
  font-family: var(--font-body);
  font-size: 0.95rem;
}

input:focus,
textarea:focus {
  outline: none;
  border-color: #b4865f;
  box-shadow: 0 0 0 3px rgba(141, 91, 51, 0.17);
}

textarea {
  resize: vertical;
}

.hp-field {
  position: absolute;
  left: -9999px;
  width: 1px;
  height: 1px;
  overflow: hidden;
}

.form-note {
  margin-top: 0.8rem;
  font-size: 0.85rem;
  color: var(--ink-muted);
}

.strip {
  background: linear-gradient(180deg, rgba(255, 250, 243, 0.52), rgba(232, 222, 206, 0.22));
  border-top: 1px solid rgba(141, 91, 51, 0.13);
  border-bottom: 1px solid rgba(141, 91, 51, 0.13);
}

.prep-wrap {
  max-width: 820px;
}

.prep-list {
  margin-top: 1rem;
  display: grid;
  gap: 0.62rem;
}

@media (max-width: 920px) {
  .contact-grid {
    grid-template-columns: 1fr;
  }

  .contact-panel {
    padding: 1.15rem;
  }
}
</style>
