---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const contactOptions = [
  {
    label: 'Projekt-Mail',
    value: 'hello@ultramind.one',
    note: 'Fuer Kooperationen, Build-Sprints und strategische Anfragen.',
    href: 'mailto:hello@ultramind.one?subject=ultramind.one%20Projektanfrage',
  },
  {
    label: 'Telegram',
    value: '@ultramind_one',
    note: 'Kurze Abstimmungen und asynchrone Sprint-Kommunikation.',
    href: 'https://t.me/ultramind_one',
  },
  {
    label: 'Session Call',
    value: '30 Minuten Discovery',
    note: 'Kickoff fuer Positionierung, Scope und Prioritaeten.',
    href: 'mailto:hello@ultramind.one?subject=ultramind.one%20Discovery%20Call',
  },
];

const prep = [
  'Welches Modul oder welcher Bereich ist gerade Prioritaet?',
  'Was soll in den naechsten 14 Tagen live gehen?',
  'Welche Inhalte sind bereits vorhanden und welche fehlen?',
];
---

<Layout
  title="Kontakt"
  description="Kontakt zu ultramind.one fuer Build-Sprints, Partnerschaften und Early-Access Gespräche."
>
  <Nav />

  <main class="page-shell" id="early-access">
    <section class="section-tight">
      <div class="container">
        <p class="eyebrow">Kontakt & Early Access</p>
        <h1 class="display-title">Lass uns ultramind.one zusammen auf den naechsten Level bringen.</h1>
        <p class="section-lead">
          Wenn du Build, Templates oder Modul-Rollout beschleunigen willst,
          starten wir mit einem fokussierten Discovery-Gespraech.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container contact-grid">
        <div class="contact-cards">
          {contactOptions.map((option) => (
            <article class="card option-card">
              <span class="chip">Kontakt</span>
              <h2>{option.label}</h2>
              <a href={option.href} target="_blank" rel="noopener">{option.value}</a>
              <p>{option.note}</p>
            </article>
          ))}
        </div>

        <aside class="panel contact-panel">
          <p class="eyebrow">Schnellanfrage</p>
          <h2>Schick uns direkt deinen Fokus fuer den naechsten Sprint.</h2>
          <form action="mailto:hello@ultramind.one" method="get" enctype="text/plain">
            <label for="subject">Betreff</label>
            <input id="subject" type="text" name="subject" placeholder="z. B. Modul 02 Build" required />

            <label for="body">Nachricht</label>
            <textarea
              id="body"
              name="body"
              rows="6"
              placeholder="Was soll als naechstes live gehen?"
              required
            ></textarea>

            <button class="btn btn-primary" type="submit">Anfrage senden</button>
          </form>
        </aside>
      </div>
    </section>

    <section class="section strip">
      <div class="container prep-wrap">
        <p class="eyebrow">Kickoff Vorbereitung</p>
        <h2 class="section-title">Wenn du diese drei Punkte vorbereitest, wird der Start deutlich schneller.</h2>
        <ul class="list-clean prep-list">
          {prep.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.contact-grid {
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  gap: 1rem;
}

.contact-cards {
  display: grid;
  gap: 0.9rem;
}

.option-card h2 {
  margin: 0.65rem 0 0.3rem;
  color: var(--ink);
  font-size: 1.2rem;
}

.option-card a {
  font-weight: 700;
}

.option-card p {
  margin-top: 0.6rem;
  font-size: 0.92rem;
}

.contact-panel {
  padding: 1.4rem;
}

.contact-panel h2 {
  margin: 0.65rem 0 1rem;
  font-size: clamp(1.4rem, 2.8vw, 2.2rem);
  color: var(--ink);
}

form {
  display: grid;
  gap: 0.68rem;
}

label {
  font-family: var(--font-mono);
  font-size: 0.73rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

input,
textarea {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: rgba(255, 250, 243, 0.9);
  color: var(--ink);
  padding: 0.78rem 0.9rem;
  font-family: var(--font-body);
  font-size: 0.95rem;
}

input:focus,
textarea:focus {
  outline: none;
  border-color: #b4865f;
  box-shadow: 0 0 0 3px rgba(141, 91, 51, 0.17);
}

textarea {
  resize: vertical;
}

.strip {
  background: linear-gradient(180deg, rgba(255, 250, 243, 0.52), rgba(232, 222, 206, 0.22));
  border-top: 1px solid rgba(141, 91, 51, 0.13);
  border-bottom: 1px solid rgba(141, 91, 51, 0.13);
}

.prep-wrap {
  max-width: 820px;
}

.prep-list {
  margin-top: 1rem;
  display: grid;
  gap: 0.62rem;
}

@media (max-width: 920px) {
  .contact-grid {
    grid-template-columns: 1fr;
  }

  .contact-panel {
    padding: 1.15rem;
  }
}
</style>
