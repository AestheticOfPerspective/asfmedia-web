---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Impressum" description="Impressum von ultramind.one.">
  <Nav />

  <main class="page-shell legal-page">
    <div class="container">
      <p class="eyebrow">Rechtliches</p>
      <h1 class="display-title">Impressum</h1>

      <article class="panel legal-note">
        <p>
          Hinweis: Diese Seite ist als Projektvorlage aufgebaut.
          Vor dem Livegang bitte Betreiberdaten, ladungsfaehige Anschrift und alle Pflichtangaben rechtssicher ergaenzen.
        </p>
      </article>

      <section class="legal-block">
        <h2>Angaben gemaess § 5 TMG</h2>
        <p>
          [Name / Firma]<br />
          [Strasse und Hausnummer]<br />
          [PLZ Ort]<br />
          [Land]
        </p>
      </section>

      <section class="legal-block">
        <h2>Kontakt</h2>
        <p>
          E-Mail: <a href="mailto:hello@ultramind.one">hello@ultramind.one</a><br />
          Telefon: [Telefonnummer]
        </p>
      </section>

      <section class="legal-block">
        <h2>Vertretungsberechtigte Person</h2>
        <p>[Name der verantwortlichen Person]</p>
      </section>

      <section class="legal-block">
        <h2>Verantwortlich fuer den Inhalt nach § 18 Abs. 2 MStV</h2>
        <p>
          [Name]<br />
          [Anschrift]
        </p>
      </section>

      <section class="legal-block">
        <h2>Haftung fuer Inhalte</h2>
        <p>
          Die Inhalte dieser Website wurden mit groesster Sorgfalt erstellt.
          Fuer Richtigkeit, Vollstaendigkeit und Aktualitaet der Inhalte wird jedoch keine Gewaehr uebernommen.
        </p>
      </section>

      <section class="legal-block">
        <h2>Urheberrecht</h2>
        <p>
          Die auf dieser Website erstellten Inhalte und Werke unterliegen dem deutschen Urheberrecht.
          Vervielfaeltigung, Bearbeitung und Verwertung ausserhalb der Grenzen des Urheberrechts beduerfen der Zustimmung.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style>
.legal-page {
  padding-bottom: 3.5rem;
}

.legal-note {
  margin-top: 1rem;
  margin-bottom: 1.2rem;
  padding: 1rem 1.1rem;
  border-left: 4px solid rgba(141, 91, 51, 0.5);
}

.legal-note p {
  color: var(--ink-soft);
  font-size: 0.94rem;
}

.legal-block {
  padding: 1.15rem 0;
  border-bottom: 1px solid var(--line);
}

.legal-block:last-child {
  border-bottom: none;
}

.legal-block h2 {
  font-size: 1.28rem;
  color: var(--ink);
  margin-bottom: 0.48rem;
}

.legal-block p {
  color: var(--ink-soft);
  line-height: 1.76;
}
</style>
