---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Impressum" description="Impressum von ASFMedia — Alexander Solod, Nürnberger Land, Bayern.">
  <Nav />

  <main class="page-shell legal-page">
    <div class="container">
      <p class="eyebrow">Rechtliches</p>
      <h1 class="display-title">Impressum</h1>

      <section class="legal-block">
        <h2>Angaben gemaess § 5 TMG</h2>
        <p>
          Alexander Solod<br />
          Nuernberger Land, Bayern<br />
          Deutschland
        </p>
      </section>

      <section class="legal-block">
        <h2>Kontakt</h2>
        <p>
          E-Mail: <a href="mailto:hello@asfmedia.org">hello@asfmedia.org</a>
        </p>
      </section>

      <section class="legal-block">
        <h2>Vertretungsberechtigte Person</h2>
        <p>Alexander Solod</p>
      </section>

      <section class="legal-block">
        <h2>Verantwortlich fuer den Inhalt nach § 18 Abs. 2 MStV</h2>
        <p>
          Alexander Solod<br />
          Nuernberger Land, Bayern
        </p>
      </section>

      <section class="legal-block">
        <h2>Haftung fuer Inhalte</h2>
        <p>
          Die Inhalte dieser Website wurden mit groesster Sorgfalt erstellt.
          Fuer Richtigkeit, Vollstaendigkeit und Aktualitaet der Inhalte wird jedoch keine Gewaehr uebernommen.
        </p>
      </section>

      <section class="legal-block">
        <h2>Urheberrecht</h2>
        <p>
          Die auf dieser Website erstellten Inhalte und Werke unterliegen dem deutschen Urheberrecht.
          Vervielfaeltigung, Bearbeitung und Verwertung ausserhalb der Grenzen des Urheberrechts beduerfen der Zustimmung.
        </p>
      </section>

      <section class="legal-block">
        <h2>Streitbeilegung</h2>
        <p>
          Wir sind nicht verpflichtet und nicht bereit, an Streitbeilegungsverfahren vor
          einer Verbraucherschlichtungsstelle teilzunehmen.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style>
.legal-page {
  padding-bottom: 3.5rem;
}

.legal-block {
  padding: 1.15rem 0;
  border-bottom: 1px solid var(--line);
}

.legal-block:last-child {
  border-bottom: none;
}

.legal-block h2 {
  font-size: 1.28rem;
  color: var(--ink);
  margin-bottom: 0.48rem;
}

.legal-block p {
  color: var(--ink-soft);
  line-height: 1.76;
}
</style>
