---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const metrics = [
  { value: '8', label: 'Intelligenzraeume' },
  { value: '01', label: 'Modul bereits spielbar' },
  { value: 'Q2 2026', label: 'Hub-Prototyp geplant' },
];

const pillars = [
  {
    title: 'Wissen wird Erfahrung',
    text: 'Jede Intelligenzform wird als eigenstaendiges Erlebnis gebaut, nicht als trockene Textseite.',
  },
  {
    title: 'Modular statt Monolith',
    text: 'Module funktionieren einzeln und wachsen spaeter in ein gemeinsames Dashboard hinein.',
  },
  {
    title: 'Design mit Fokus',
    text: 'Klare Typografie, ruhige Premium-Aesthetik und spielerische Interaktion statt visueller Ueberladung.',
  },
];

const roadmap = [
  { id: '01', name: 'Koerperlich-Kinaesthetisch', state: 'Live', note: 'Interaktives Quiz inklusive Feedback und Score-Logik.' },
  { id: '02', name: 'Logisch-Mathematisch', state: 'In Planung', note: 'Strukturierte Aufgaben, Mustererkennung und Transferfragen.' },
  { id: '03', name: 'Musikalisch-Rhythmisch', state: 'In Planung', note: 'Rhythmus, Klangmuster und Wahrnehmungsaufgaben.' },
  { id: '04', name: 'Sprachlich-Linguistisch', state: 'In Planung', note: 'Wort, Ausdruck und Bedeutungsraum mit interaktiven Uebungen.' },
  { id: '05', name: 'Raeumlich-Visuell', state: 'In Planung', note: 'Raumvorstellung, Bilddenken und visuelle Loesungswege.' },
  { id: '06', name: 'Interpersonal', state: 'In Planung', note: 'Teamdynamik, Empathie und kommunikative Entscheidungslogik.' },
  { id: '07', name: 'Intrapersonal', state: 'In Planung', note: 'Selbstwahrnehmung, Reflexion und innere Muster.' },
  { id: '08', name: 'Naturalistisch', state: 'In Planung', note: 'Beobachten, Ordnen und Muster in natuerlichen Systemen.' },
];

const templateCards = [
  {
    name: 'Landing Blueprint',
    text: 'Hero, Storyline, Trust-Signale und klare Conversion in einem wiederverwendbaren Aufbau.',
    tags: ['Launch', 'Pitch', 'Conversion'],
  },
  {
    name: 'Modul Template',
    text: 'Standardstruktur fuer jedes Intelligenz-Modul mit Intro, Quiz, Feedback und Ergebnisansicht.',
    tags: ['Lernen', 'Quiz', 'Scoring'],
  },
  {
    name: 'Hub Dashboard',
    text: 'Zentraler Einstieg fuer Fortschritt, Modul-Status und spaetere Empfehlungen.',
    tags: ['Roadmap', 'Tracking', 'Growth'],
  },
];

const sprintPlan = [
  {
    step: 'Positionierung fixieren',
    detail: 'Ton, Zielgruppe, Value Proposition und inhaltliche Leitplanken abstimmen.',
  },
  {
    step: 'Designsystem setzen',
    detail: 'Farben, Typografie, Komponenten und Motion-Bausteine verbindlich definieren.',
  },
  {
    step: 'Site + Templates bauen',
    detail: 'Landingpage, Modul-Uebersicht und wiederverwendbare Seitenvorlagen umsetzen.',
  },
  {
    step: 'Modul-Rollout starten',
    detail: 'Modul 02 priorisieren und den Hub-Rahmen fuer die naechsten Sprints vorbereiten.',
  },
];
---

<Layout
  title="ultramind.one"
  description="ultramind.one ist ein modulares Lernuniversum, das die 8 Intelligenzformen als interaktive Erfahrungen erlebbar macht."
>
  <Nav />

  <main class="page-shell">
    <section class="hero section-tight">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Nikita x Fossnomade · Projektstatus 2026</p>
          <h1 class="display-title">Intelligenz wird hier erlebbar, nicht nur erklaert.</h1>
          <p class="section-lead">
            ultramind.one baut eine modulare Lernreise durch die acht Intelligenzformen nach Gardner.
            Statt Frontalunterricht entstehen interaktive Raume, in denen Menschen sich selbst besser verstehen.
          </p>
          <div class="hero-cta">
            <a class="btn btn-primary" href="/module">Module entdecken</a>
            <a class="btn btn-ghost" href="/contact">Projektgespraech starten</a>
          </div>
          <div class="chip-row">
            <span class="chip">Deutsch zuerst</span>
            <span class="chip">Clean Premium Design</span>
            <span class="chip">Vanilla Quiz x Astro Site</span>
          </div>
        </div>

        <aside class="panel hero-card">
          <p class="eyebrow">Proof of Concept</p>
          <h2>Modul 01 ist live und validiert den Ansatz.</h2>
          <ul class="list-clean hero-list">
            <li>Themenlogik abgeschlossen</li>
            <li>Interaktives Quiz bereits spielbar</li>
            <li>Feedback-Mechanik inklusive Erklaerungen</li>
            <li>Score-Auswertung und Ergebnis-Readout aktiv</li>
          </ul>
          <a href="/module" class="hero-link">Zum Modul-Board</a>
        </aside>
      </div>

      <div class="container metric-grid">
        {metrics.map((metric) => (
          <article class="panel metric-card">
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="container">
        <p class="eyebrow">Warum ultramind.one</p>
        <h2 class="section-title">Ein Lernsystem fuer Menschen, nicht fuer Schubladen.</h2>
        <p class="section-lead">
          Das Projekt verbindet Bildung, Design und Interaktion. Jede Einheit steht fuer einen
          konkreten Intelligenzraum, bleibt aber Teil einer groesseren Reise.
        </p>
        <div class="grid-3 card-grid">
          {pillars.map((pillar) => (
            <article class="card value-card">
              <h3>{pillar.title}</h3>
              <p>{pillar.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-roadmap">
      <div class="container">
        <p class="eyebrow">Roadmap</p>
        <h2 class="section-title">Alle acht Module in einem klaren Rollout.</h2>
        <div class="roadmap-grid">
          {roadmap.map((item) => (
            <article class="card roadmap-card">
              <div class="roadmap-head">
                <span class="chip">Modul {item.id}</span>
                <span class:list={['status-pill', item.state === 'Live' && 'status-live']}>
                  {item.state}
                </span>
              </div>
              <h3>{item.name}</h3>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <p class="eyebrow">Template Vorlagen</p>
        <h2 class="section-title">Wiederverwendbare Bausteine fuer schnellen Ausbau.</h2>
        <p class="section-lead">
          Jede Vorlage folgt derselben Designlogik und kann pro Modul, Landing oder Kampagne adaptiert werden.
        </p>
        <div class="grid-3 card-grid">
          {templateCards.map((template) => (
            <article class="card template-card">
              <h3>{template.name}</h3>
              <p>{template.text}</p>
              <div class="chip-row">
                {template.tags.map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-roadmap">
      <div class="container">
        <p class="eyebrow">Naechster Sprint</p>
        <h2 class="section-title">So geht der Build in vier Schritten weiter.</h2>
        <div class="timeline-grid">
          {sprintPlan.map((item, index) => (
            <article class="card timeline-card">
              <span class="chip">Schritt {index + 1}</span>
              <h3>{item.step}</h3>
              <p>{item.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="panel cta-panel">
          <p class="eyebrow">Launchbereit machen</p>
          <h2>Du willst ultramind.one direkt produktiv ausrollen?</h2>
          <p>
            Dann setzen wir als naechstes Domain, Inhalte, Modul 02 und den Hub-Rahmen final auf.
            Danach ist die Plattform bereit fuer den kontinuierlichen Ausbau.
          </p>
          <div class="hero-cta">
            <a href="/contact" class="btn btn-primary">Kontakt aufnehmen</a>
            <a href="/templates" class="btn btn-ghost">Templates ansehen</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.hero-grid {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 1.3rem;
  align-items: start;
}

.hero-copy {
  padding: 1rem 0;
}

.hero-cta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  margin-top: 1.6rem;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1.2rem;
}

.hero-card {
  padding: 1.35rem;
}

.hero-card h2 {
  font-size: 1.7rem;
  margin: 0.65rem 0 1rem;
}

.hero-list {
  display: grid;
  gap: 0.5rem;
}

.hero-list li {
  font-size: 0.95rem;
}

.hero-link {
  display: inline-block;
  margin-top: 1rem;
  font-weight: 700;
}

.metric-grid {
  margin-top: 1.2rem;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
}

.metric-card {
  padding: 1rem 1.1rem;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.metric-card strong {
  color: var(--ink);
  font-size: 1.45rem;
  font-family: var(--font-display);
}

.metric-card span {
  color: var(--ink-muted);
  font-size: 0.9rem;
}

.card-grid {
  margin-top: 1.35rem;
}

.value-card h3,
.template-card h3,
.timeline-card h3,
.roadmap-card h3 {
  color: var(--ink);
  font-size: 1.12rem;
  margin-bottom: 0.5rem;
}

.value-card p,
.template-card p,
.timeline-card p,
.roadmap-card p {
  font-size: 0.95rem;
  line-height: 1.68;
}

.section-roadmap {
  background: linear-gradient(180deg, rgba(255, 250, 243, 0.55), rgba(232, 222, 206, 0.26));
  border-top: 1px solid rgba(141, 91, 51, 0.13);
  border-bottom: 1px solid rgba(141, 91, 51, 0.13);
}

.roadmap-grid {
  margin-top: 1.25rem;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.roadmap-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.8rem;
  margin-bottom: 0.8rem;
}

.status-pill {
  border-radius: 999px;
  border: 1px solid var(--line);
  font-family: var(--font-mono);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--ink-muted);
  padding: 0.24rem 0.56rem;
}

.status-live {
  border-color: rgba(47, 122, 79, 0.42);
  color: var(--success);
  background: rgba(47, 122, 79, 0.1);
}

.timeline-grid {
  margin-top: 1.25rem;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0.9rem;
}

.cta-panel {
  padding: 2.2rem;
}

.cta-panel h2 {
  margin: 0.7rem 0;
  font-size: clamp(1.8rem, 3.5vw, 2.9rem);
  color: var(--ink);
}

.cta-panel p {
  max-width: 720px;
}

@media (max-width: 1020px) {
  .hero-grid {
    grid-template-columns: 1fr;
  }

  .timeline-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 760px) {
  .metric-grid,
  .roadmap-grid,
  .timeline-grid {
    grid-template-columns: 1fr;
  }

  .hero-card,
  .cta-panel {
    padding: 1.25rem;
  }
}
</style>
