---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const personas = [
  {
    tag: 'Kreation',
    title: 'Creative Director & Illustrator',
    text: 'Visuelle Konzepte, Brand Identity, Character Design und Illustrationen. Ich denke in Bildern — und bringe sie in Form.',
    link: { label: 'Services ansehen', href: '/services' },
  },
  {
    tag: 'Development',
    title: 'Developer auf Lernreise',
    text: 'Python, Bots, API-Integrationen, Web-Builds. Ich lerne täglich, baue was ich lerne und pushe in Produktion.',
    link: { label: 'Dev Journey', href: '/dev' },
  },
  {
    tag: 'Content',
    title: 'Commentary & Media Creator',
    text: 'Jutsu Gaming, Streaming, Editing und Commentary. Ich bringe Energie, Perspektive und einen eigenen Ton.',
    link: { label: 'Media & Ecosystem', href: '/media' },
  },
];

const metrics = [
  { value: '3×', label: 'Personas aktiv' },
  { value: 'Python', label: 'Lernreise 2026' },
  { value: '2+', label: 'Projekte live' },
  { value: 'Bayern', label: 'Nürnberger Land' },
];

const ecosystem = [
  {
    tag: 'Cloud',
    name: 'cloud.asfmedia.org',
    desc: 'Private Nextcloud — Dateien, Sync, Kollaboration.',
    status: 'Online',
    href: 'https://cloud.asfmedia.org',
  },
  {
    tag: 'Music',
    name: 'Navidrome',
    desc: 'Eigener Music Server via Subsonic API auf Docker.',
    status: 'Online',
    href: null,
  },
  {
    tag: 'Community',
    name: 'Jutsu Gaming',
    desc: 'Streaming, Gaming-Community, Commentary Content.',
    status: 'Aktiv',
    href: null,
  },
  {
    tag: 'AI Stack',
    name: 'Claude · Ollama · Copilot',
    desc: 'AI-Tool-Chain für Entwicklung und kreative Arbeit.',
    status: 'Running',
    href: null,
  },
];

const services = [
  {
    label: 'Creative Direction',
    text: 'Brand Identity, Visual Konzepte, Illustration und Designsysteme.',
  },
  {
    label: 'Media Produktion',
    text: 'Video Editing, Content Creation, Commentary, Streaming Assets.',
  },
  {
    label: 'Tech & Automation',
    text: 'Web Builds, Bots, Python Scripts, AI Integration.',
  },
];
---

<Layout
  title="ASFMedia"
  description="Fossnomade / ASFMedia — Creative Director, Illustrator, Developer und Digital Creator. Creative Direction, Media, Tech und alles dazwischen."
>
  <Nav />

  <main class="page-shell">
    <!-- HERO -->
    <section class="hero section-tight">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">ASFMedia · Nürnberger Land · 2026</p>
          <h1 class="display-title">Ich kreiere,<br />code und<br />kommentiere.</h1>
          <p class="section-lead">
            Creative Director, Illustrator, Entwickler im Aufbau und Commentary Guy.
            Egal ob Illustration, Python-Script oder Stream — alles trägt dieselbe Handschrift.
          </p>
          <div class="hero-cta">
            <a class="btn btn-primary" href="/services">Services entdecken</a>
            <a class="btn btn-ghost" href="/dev">Dev Journey →</a>
          </div>
          <div class="chip-row">
            <span class="chip">Creative Director</span>
            <span class="chip">Illustrator</span>
            <span class="chip">Python</span>
            <span class="chip">Jutsu Gaming</span>
            <span class="chip">Commentary</span>
          </div>
        </div>

        <aside class="panel hero-card">
          <p class="eyebrow">Status · Live</p>
          <h2>Das Command Center läuft.</h2>
          <ul class="status-list">
            <li><span class="status-dot online"></span>cloud.asfmedia.org</li>
            <li><span class="status-dot online"></span>Navidrome Music</li>
            <li><span class="status-dot active"></span>Python Journey</li>
            <li><span class="status-dot active"></span>AI Stack</li>
            <li><span class="status-dot active"></span>ASFMedia Site</li>
          </ul>
          <a href="/services" class="hero-link">Alle Services ansehen →</a>
        </aside>
      </div>

      <div class="container metric-grid">
        {metrics.map((m) => (
          <article class="panel metric-card">
            <strong>{m.value}</strong>
            <span>{m.label}</span>
          </article>
        ))}
      </div>
    </section>

    <!-- WHO -->
    <section class="section section-stripe">
      <div class="container">
        <p class="eyebrow">Wer ich bin</p>
        <h2 class="section-title">Drei Rollen. Eine Handschrift.</h2>
        <p class="section-lead">
          Fossnomade ist Künstler, Builder und Kommentator in einem.
          Je nach Kontext die passende Rolle — aber immer derselbe Drive.
        </p>
        <div class="grid-3 card-grid">
          {personas.map((p) => (
            <article class="card persona-card">
              <span class="chip">{p.tag}</span>
              <h3>{p.title}</h3>
              <p>{p.text}</p>
              <a href={p.link.href} class="card-link">{p.link.label} →</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ECOSYSTEM -->
    <section class="section">
      <div class="container">
        <p class="eyebrow">Das Ecosystem</p>
        <h2 class="section-title">Alles läuft. Alles connected.</h2>
        <p class="section-lead">
          Eigene Infrastruktur, eigener Music Server, eigene Community.
          Das Ecosystem wächst mit jedem Sprint.
        </p>
        <div class="grid-4 card-grid">
          {ecosystem.map((item) => (
            <article class="card eco-card">
              <div class="eco-head">
                <span class="chip">{item.tag}</span>
                <span class="status-pill">{item.status}</span>
              </div>
              <h3>{item.name}</h3>
              <p>{item.desc}</p>
              {item.href && (
                <a href={item.href} target="_blank" rel="noopener" class="card-link">Öffnen →</a>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- SERVICES PREVIEW -->
    <section class="section section-stripe">
      <div class="container">
        <p class="eyebrow">Services</p>
        <h2 class="section-title">Was ich für dich bauen kann.</h2>
        <p class="section-lead">
          Meisterdienstleister für digitale Kreation. Ob Marke, Inhalt oder Technik —
          ich liefere das Gesamtpaket oder den gezielten Build.
        </p>
        <div class="grid-3 card-grid">
          {services.map((s) => (
            <article class="card service-card">
              <h3>{s.label}</h3>
              <p>{s.text}</p>
            </article>
          ))}
        </div>
        <div class="section-cta">
          <a href="/services" class="btn btn-primary">Alle Services ansehen</a>
          <a href="/contact" class="btn btn-ghost">Direkt anfragen</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section">
      <div class="container">
        <div class="panel cta-panel">
          <p class="eyebrow">Let's Go</p>
          <h2>Du hast ein Projekt. Ich hab Tools, Vision und einen Laptop auf 100%.</h2>
          <p>
            Illustration, Site-Build, Bot, Video-Edit oder alles auf einmal —
            lass uns einen Sprint starten.
          </p>
          <div class="cta-actions">
            <a href="/contact" class="btn btn-primary">Kontakt aufnehmen</a>
            <a href="/services" class="btn btn-ghost">Services ansehen</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.hero-grid {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 1.3rem;
  align-items: start;
}

.hero-copy { padding: 1rem 0; }

.hero-cta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  margin-top: 1.6rem;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1.2rem;
}

.hero-card { padding: 1.5rem; }

.hero-card h2 {
  font-size: 1.7rem;
  color: var(--ink);
  margin: 0.65rem 0 1rem;
}

.status-list {
  list-style: none;
  display: grid;
  gap: 0.55rem;
}

.status-list li {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.95rem;
  color: var(--ink-soft);
  padding-left: 0;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.online {
  background: var(--success);
  box-shadow: 0 0 8px rgba(34, 197, 94, 0.5);
}

.status-dot.active {
  background: var(--cyan);
  box-shadow: 0 0 8px rgba(30, 232, 208, 0.5);
}

.hero-link {
  display: inline-block;
  margin-top: 1rem;
  font-weight: 700;
  font-size: 0.9rem;
  color: var(--cyan);
}

.metric-grid {
  margin-top: 1.2rem;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rem;
}

.metric-card {
  padding: 1rem 1.1rem;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.metric-card strong {
  color: var(--cyan);
  font-size: 1.45rem;
  font-family: var(--font-display);
}

.metric-card span {
  color: var(--ink-muted);
  font-size: 0.88rem;
  font-family: var(--font-mono);
}

.section-stripe {
  background: rgba(30, 232, 208, 0.02);
  border-top: 1px solid rgba(30, 232, 208, 0.07);
  border-bottom: 1px solid rgba(30, 232, 208, 0.07);
}

.card-grid { margin-top: 1.35rem; }

.persona-card,
.service-card {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.persona-card h3,
.service-card h3,
.eco-card h3 {
  color: var(--ink);
  font-size: 1.1rem;
  margin-top: 0.4rem;
}

.persona-card p,
.service-card p,
.eco-card p {
  font-size: 0.95rem;
  line-height: 1.68;
  flex: 1;
}

.card-link {
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--cyan);
  margin-top: 0.4rem;
}

.card-link:hover { color: var(--amber); }

.eco-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.6rem;
  margin-bottom: 0.6rem;
}

.eco-card {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.status-pill {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.2rem 0.5rem;
  border-radius: 999px;
  border: 1px solid rgba(34, 197, 94, 0.3);
  color: var(--success);
  background: rgba(34, 197, 94, 0.08);
  white-space: nowrap;
}

.section-cta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin-top: 2rem;
}

.cta-panel { padding: 2.2rem; }

.cta-panel h2 {
  margin: 0.7rem 0 0.8rem;
  font-size: clamp(1.8rem, 3.5vw, 2.9rem);
  color: var(--ink);
}

.cta-panel p { max-width: 720px; }

.cta-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin-top: 1.5rem;
}

@media (max-width: 1020px) {
  .hero-grid { grid-template-columns: 1fr; }
  .metric-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}

@media (max-width: 760px) {
  .hero-card,
  .cta-panel { padding: 1.25rem; }
}
</style>
