---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    title: "GodFather Bot",
    description: "Telegram-Bot mit 7 KI-Personas, Voice-Commands (Whisper STT), Text-to-Speech und Moderations-System. Vollständig offline via Ollama + Llama 3.1.",
    tags: ["Python", "Ollama", "Telegram", "Docker"],
    icon: "🤖",
  },
  {
    title: "Life.Play Platform",
    description: "KI-Persona-System mit 6+1 Agenten für verschiedene Kontexte — von Cyber-Zen bis Punk-Philosopher. Monetarisiert via eigenem Platform-Ökosystem.",
    tags: ["AI", "Personas", "Life.Play"],
    icon: "⚡",
  },
  {
    title: "ASFMedia Cloud",
    description: "Selbst gehostete Nextcloud-Infrastruktur für Team-Kollaboration, Datei-Sync und Client-Delivery. FOSS, privat, unter eigener Kontrolle.",
    tags: ["Nextcloud", "Self-hosted", "FOSS"],
    icon: "☁️",
  },
];

const personas = [
  { name: "GodFather", desc: "Mafia-Boss Weisheit + Humor", voice: "Conrad Neural" },
  { name: "Cyber-Zen", desc: "KI-Mönch mit Zen-Metaphern", voice: "Killian Neural" },
  { name: "Vapor-FOSS", desc: "Chill Hacker, Vaporwave-Vibe", voice: "Florian Neural" },
  { name: "Punk-Philosopher", desc: "Rebellischer Intellektueller", voice: "Killian Neural" },
  { name: "Monkey-Mind", desc: "Chaotischer Poet", voice: "Conrad Neural" },
  { name: "Nyx.exe", desc: "Digital Muse · Agent 6", voice: "Katja Neural" },
];

const games = [
  { title: "Stellaris", series: "Yatun Empire Arc", emoji: "🌌" },
  { title: "Cyberpunk 2077", series: "Night City Explodes", emoji: "🔥" },
  { title: "Factorio Space Age", series: "Mega Factory oder Total Meltdown?", emoji: "🏭" },
  { title: "Dragon Age Origins", series: "Nightmare Mode", emoji: "⚔️" },
  { title: "Minecraft", series: "Choom City in the Hole", emoji: "🏙️" },
  { title: "Cobblemon Academy", series: "Pokemon × Minecraft", emoji: "⚡" },
];
---

<Layout title="Alexander Solod – Digital Creator, Developer & Streamer">
  <Nav />

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-tag tag">// system.boot() → ASFMedia_v2.0</div>
      <h1 class="hero-title">
        Alexander <span class="cyan glow">Solod</span>
      </h1>
      <p class="hero-subtitle">Digital Creator · Developer · Streamer</p>
      <p class="hero-location">📍 Nürnberger Land, Bayern</p>
      <p class="hero-desc">
        Ich baue KI-Personas, Telegram-Bots und Streaming-Setups —<br />
        alles mit <span class="cyan">Cyberpunk Dharma</span> Philosophie. FOSS wo immer möglich.
      </p>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">Projekte ansehen</a>
        <a href="#contact" class="btn btn-outline">Kontakt</a>
      </div>
      <div class="hero-stack">
        {["Python", "Ollama", "Docker", "Astro", "Obsidian", "Linux"].map(t => (
          <span class="tag">{t}</span>
        ))}
      </div>
    </div>
    <div class="hero-grid-overlay"></div>
  </section>

  <!-- PROJEKTE -->
  <section id="projects" class="section">
    <div class="container">
      <h2 class="section-title">Projekte</h2>
      <p class="section-subtitle">Was ich baue — und warum es wichtig ist</p>
      <div class="projects-grid">
        {projects.map(p => (
          <div class="card">
            <div class="project-icon">{p.icon}</div>
            <h3 class="project-title">{p.title}</h3>
            <p class="project-desc">{p.description}</p>
            <div class="project-tags">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LIFE.PLAY PERSONAS -->
  <section id="lifeplay" class="section section-dark">
    <div class="container">
      <h2 class="section-title">Life.Play · KI-Personas</h2>
      <p class="section-subtitle">7 Agenten. Ein System. Unendliche Kontexte.</p>
      <div class="personas-grid">
        {personas.map(p => (
          <div class="card persona-card">
            <h3 class="persona-name">{p.name}</h3>
            <p class="persona-desc">{p.desc}</p>
            <span class="tag">{p.voice}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STREAMING -->
  <section id="streaming" class="section">
    <div class="container">
      <h2 class="section-title">JutsuGaming · Streaming</h2>
      <p class="section-subtitle">3x pro Woche · 20:00 Uhr · Twitch · Cyberpunk Dharma Philosophie</p>
      <div class="games-grid">
        {games.map(g => (
          <div class="card game-card">
            <span class="game-emoji">{g.emoji}</span>
            <h3 class="game-title">{g.title}</h3>
            <p class="game-series">{g.series}</p>
          </div>
        ))}
      </div>
      <div class="stream-cta">
        <a href="https://twitch.tv/jutsugaming" target="_blank" rel="noopener" class="btn btn-primary">
          Auf Twitch folgen
        </a>
      </div>
    </div>
  </section>

  <!-- ÜBER MICH -->
  <section id="about" class="section section-dark">
    <div class="container about-inner">
      <div>
        <h2 class="section-title">Über mich</h2>
        <p class="about-text">
          Ich bin Alexander Solod — Fossnomade. Digital Creator, Entwickler und Streamer aus dem Nürnberger Land.
        </p>
        <p class="about-text">
          Meine Philosophie heißt <span class="cyan">Cyberpunk Dharma</span>: Technologie als Werkzeug zur persönlichen und kollektiven Befreiung — mit einem FOSS-Ethos, Gamer-Energie und echtem Herz.
        </p>
        <p class="about-text">
          Ich baue KI-Bots, Streaming-Setups und Plattformen die Menschen wirklich helfen. Helfen ist mein Antrieb.
        </p>
        <div class="about-tags">
          {["FOSS Advocate", "AI Builder", "Streamer", "Photographer", "Cyberpunk Dharma"].map(t => (
            <span class="tag">{t}</span>
          ))}
        </div>
      </div>
      <div class="about-photo-placeholder">
        <div class="photo-box">
          <span>A</span>
        </div>
      </div>
    </div>
  </section>

  <!-- KONTAKT -->
  <section id="contact" class="section">
    <div class="container contact-inner">
      <h2 class="section-title">Kontakt</h2>
      <p class="section-subtitle">Projekt? Kollaboration? Einfach quatschen? Schreib mir!</p>
      <div class="contact-grid">
        <div class="contact-info">
          <div class="contact-item">
            <span class="contact-label">// email</span>
            <a href="mailto:alexander.solod@web.de">alexander.solod@web.de</a>
          </div>
          <div class="contact-item">
            <span class="contact-label">// standort</span>
            <span>Nürnberger Land, Bayern</span>
          </div>
          <div class="contact-item">
            <span class="contact-label">// telegram</span>
            <a href="https://t.me/fossnomade" target="_blank" rel="noopener">@fossnomade</a>
          </div>
          <div class="contact-item">
            <span class="contact-label">// twitch</span>
            <a href="https://twitch.tv/jutsugaming" target="_blank" rel="noopener">JutsuGaming</a>
          </div>
        </div>
        <form class="contact-form" action="mailto:alexander.solod@web.de" method="get">
          <input type="text" name="subject" placeholder="Betreff" required />
          <textarea name="body" placeholder="Deine Nachricht..." rows="5" required></textarea>
          <button type="submit" class="btn btn-primary">Nachricht senden</button>
        </form>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.hero-grid-overlay {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0, 194, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 194, 255, 0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
}

.hero-inner {
  padding-top: 6rem;
  padding-bottom: 4rem;
  position: relative;
  z-index: 1;
}

.hero-tag { margin-bottom: 1.5rem; }

.hero-title {
  font-size: clamp(3rem, 8vw, 6rem);
  margin-bottom: 0.5rem;
}

.cyan { color: var(--cyan); }

.hero-subtitle {
  font-family: var(--font-mono);
  color: var(--text-muted);
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
}

.hero-location {
  color: var(--text-muted);
  font-size: 0.9rem;
  margin-bottom: 1.5rem;
}

.hero-desc {
  font-size: 1.1rem;
  max-width: 580px;
  color: #cccccc;
  margin-bottom: 2.5rem;
  line-height: 1.8;
}

.hero-cta {
  display: flex;
  gap: 1rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
}

.hero-stack {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.5rem;
}

.project-icon {
  font-size: 2rem;
  margin-bottom: 1rem;
}

.project-title {
  font-size: 1.2rem;
  color: var(--cyan);
  margin-bottom: 0.75rem;
}

.project-desc {
  color: var(--text-muted);
  font-size: 0.9rem;
  margin-bottom: 1.25rem;
  line-height: 1.7;
}

.project-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.section-dark {
  background: rgba(0, 194, 255, 0.02);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.personas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}

.persona-name {
  font-size: 1rem;
  color: var(--cyan);
  margin-bottom: 0.5rem;
}

.persona-desc {
  color: var(--text-muted);
  font-size: 0.85rem;
  margin-bottom: 0.75rem;
}

.games-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
  margin-bottom: 2.5rem;
}

.game-card { text-align: center; padding: 1.5rem 1rem; }

.game-emoji {
  font-size: 2rem;
  display: block;
  margin-bottom: 0.75rem;
}

.game-title {
  font-size: 0.95rem;
  color: var(--cyan);
  margin-bottom: 0.4rem;
}

.game-series {
  color: var(--text-muted);
  font-size: 0.8rem;
}

.stream-cta { text-align: center; }

.about-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4rem;
  align-items: center;
}

.about-text {
  color: #cccccc;
  margin-bottom: 1.25rem;
  font-size: 1rem;
  line-height: 1.8;
}

.about-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-top: 1.5rem;
}

.photo-box {
  width: 220px;
  height: 220px;
  border: 2px solid var(--cyan);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 5rem;
  color: var(--cyan);
  background: rgba(0, 194, 255, 0.05);
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
}

.contact-item { margin-bottom: 1.5rem; }

.contact-label {
  display: block;
  font-family: var(--font-mono);
  color: var(--text-muted);
  font-size: 0.8rem;
  margin-bottom: 0.25rem;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.contact-form input,
.contact-form textarea {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 0.75rem 1rem;
  color: var(--text);
  font-family: var(--font-body);
  font-size: 0.95rem;
  transition: border-color 0.2s;
  resize: vertical;
}

.contact-form input:focus,
.contact-form textarea:focus {
  outline: none;
  border-color: var(--cyan);
}

.contact-form input::placeholder,
.contact-form textarea::placeholder {
  color: var(--text-muted);
}

@media (max-width: 768px) {
  .about-inner { grid-template-columns: 1fr; }
  .photo-box { display: none; }
  .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
}
</style>
