---
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'Start' },
  { href: '/module', label: 'Module' },
  { href: '/templates', label: 'Templates' },
  { href: '/about', label: 'Projekt' },
  { href: '/contact', label: 'Kontakt' },
];

const isActive = (href: string) => (href === '/' ? pathname === '/' : pathname.startsWith(href));
---

<nav class="site-nav" data-nav-root>
  <div class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="Zur Startseite von ultramind.one">
      <span>ultramind</span><small>.one</small>
    </a>

    <button
      type="button"
      class="nav-toggle"
      aria-label="Navigation öffnen"
      aria-expanded="false"
      aria-controls="main-nav-links"
      data-nav-toggle
    >
      Menü
    </button>

    <ul class="nav-links" id="main-nav-links" data-nav-links>
      {links.map((link) => (
        <li>
          <a class:list={['nav-link', isActive(link.href) && 'is-active']} href={link.href}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="/contact" class="nav-cta">Early Access</a>
  </div>
</nav>

<style>
.site-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(245, 239, 229, 0.86);
  border-bottom: 1px solid rgba(141, 91, 51, 0.17);
  backdrop-filter: blur(10px);
}

.nav-inner {
  min-height: 74px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 1rem;
}

.nav-logo {
  display: inline-flex;
  align-items: baseline;
  gap: 0.12rem;
  color: var(--ink);
}

.nav-logo span {
  font-family: var(--font-display);
  font-size: 1.45rem;
  line-height: 1;
}

.nav-logo small {
  font-family: var(--font-mono);
  color: var(--ink-muted);
  font-size: 0.78rem;
  letter-spacing: 0.04em;
}

.nav-links {
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.2rem;
}

.nav-link {
  display: inline-block;
  color: var(--ink-soft);
  font-size: 0.92rem;
  font-weight: 600;
  padding: 0.42rem 0.72rem;
  border-radius: 999px;
}

.nav-link:hover {
  color: var(--ink);
  background: rgba(141, 91, 51, 0.09);
}

.is-active {
  color: var(--accent-strong);
  background: var(--accent-soft);
}

.nav-cta {
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 0.5rem 0.92rem;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--ink);
  background: rgba(255, 250, 243, 0.78);
}

.nav-cta:hover {
  border-color: var(--accent);
  color: var(--accent-strong);
}

.nav-toggle {
  display: none;
  justify-self: end;
  border: 1px solid var(--line);
  background: rgba(255, 250, 243, 0.72);
  color: var(--ink);
  border-radius: 999px;
  padding: 0.4rem 0.8rem;
  font-family: var(--font-mono);
  font-size: 0.76rem;
  letter-spacing: 0.03em;
}

@media (max-width: 920px) {
  .nav-inner {
    grid-template-columns: auto auto;
  }

  .nav-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .nav-cta {
    display: none;
  }

  .nav-links {
    position: absolute;
    left: 0;
    right: 0;
    top: 74px;
    margin: 0;
    padding: 1rem;
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: 0.45rem;
    background: rgba(245, 239, 229, 0.98);
    border-bottom: 1px solid rgba(141, 91, 51, 0.17);
  }

  .nav-links.open {
    display: flex;
  }

  .nav-link {
    width: 100%;
    border: 1px solid transparent;
    background: rgba(255, 250, 243, 0.7);
    text-align: center;
  }

  .is-active {
    border-color: rgba(141, 91, 51, 0.27);
  }
}
</style>

<script>
const root = document.querySelector('[data-nav-root]');

if (root) {
  const toggle = root.querySelector('[data-nav-toggle]');
  const links = root.querySelector('[data-nav-links]');
  const navLinks = root.querySelectorAll('.nav-link');

  const closeMenu = () => {
    links?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
  };

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    links?.classList.toggle('open');
  });

  navLinks.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 920) {
      closeMenu();
    }
  });
}
</script>
