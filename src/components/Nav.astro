---
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'Start' },
  { href: '/dev', label: 'Dev' },
  { href: '/media', label: 'Media' },
  { href: '/blog', label: 'Blog' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Kontakt' },
];

const isActive = (href: string) => (href === '/' ? pathname === '/' : pathname.startsWith(href));
---

<nav class="site-nav" data-nav-root>
  <div class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="ASFMedia – Startseite">
      <span class="logo-brand">ASF</span><em class="logo-name">media</em>
    </a>

    <button
      type="button"
      class="nav-toggle"
      aria-label="Navigation öffnen"
      aria-expanded="false"
      aria-controls="main-nav-links"
      data-nav-toggle
    >
      Menü
    </button>

    <ul class="nav-links" id="main-nav-links" data-nav-links>
      {links.map((link) => (
        <li>
          <a class:list={['nav-link', isActive(link.href) && 'is-active']} href={link.href}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="/contact" class="nav-cta">Hire Me →</a>
  </div>
</nav>

<style>
.site-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(8, 12, 20, 0.88);
  border-bottom: 1px solid rgba(30, 232, 208, 0.12);
  backdrop-filter: blur(12px);
}

.nav-inner {
  min-height: 74px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 1rem;
}

.nav-logo {
  display: inline-flex;
  align-items: baseline;
  gap: 0.1rem;
  text-decoration: none;
}

.logo-brand {
  font-family: var(--font-mono);
  font-size: 1.05rem;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.logo-name {
  font-family: var(--font-display);
  font-size: 1.45rem;
  font-style: italic;
  color: var(--cyan);
  line-height: 1;
  transition: color 0.2s;
}

.nav-logo:hover .logo-name {
  color: var(--amber);
}

.nav-links {
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.4rem;
}

.nav-link {
  display: inline-block;
  color: var(--ink-soft);
  font-size: 0.92rem;
  font-weight: 600;
  padding: 0.42rem 0.72rem;
  border-radius: 999px;
  transition: color 0.2s, background 0.2s;
}

.nav-link:hover {
  color: var(--ink);
  background: rgba(30, 232, 208, 0.08);
}

.is-active {
  color: var(--cyan);
  background: rgba(30, 232, 208, 0.1);
}

.nav-cta {
  border: 1px solid var(--cyan-border);
  border-radius: 999px;
  padding: 0.5rem 1rem;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--cyan);
  background: rgba(30, 232, 208, 0.06);
  font-family: var(--font-mono);
  letter-spacing: 0.02em;
  transition: all 0.2s;
}

.nav-cta:hover {
  background: var(--cyan);
  color: var(--void);
  border-color: var(--cyan);
}

.nav-toggle {
  display: none;
  justify-self: end;
  border: 1px solid var(--cyan-border);
  background: rgba(30, 232, 208, 0.05);
  color: var(--ink);
  border-radius: 999px;
  padding: 0.4rem 0.8rem;
  font-family: var(--font-mono);
  font-size: 0.76rem;
  letter-spacing: 0.03em;
}

@media (max-width: 920px) {
  .nav-inner {
    grid-template-columns: auto auto;
  }

  .nav-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .nav-cta {
    display: none;
  }

  .nav-links {
    position: absolute;
    left: 0;
    right: 0;
    top: 74px;
    margin: 0;
    padding: 1rem;
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: 0.45rem;
    background: rgba(8, 12, 20, 0.98);
    border-bottom: 1px solid rgba(30, 232, 208, 0.12);
  }

  .nav-links.open {
    display: flex;
  }

  .nav-link {
    width: 100%;
    border: 1px solid transparent;
    background: var(--void-2);
    text-align: center;
  }

  .is-active {
    border-color: rgba(30, 232, 208, 0.2);
  }
}
</style>

<script>
const root = document.querySelector('[data-nav-root]');

if (root) {
  const toggle = root.querySelector('[data-nav-toggle]');
  const links = root.querySelector('[data-nav-links]');
  const navLinks = root.querySelectorAll('.nav-link');

  const closeMenu = () => {
    links?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
  };

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    links?.classList.toggle('open');
  });

  navLinks.forEach((link) => link.addEventListener('click', closeMenu));

  window.addEventListener('resize', () => {
    if (window.innerWidth > 920) closeMenu();
  });
}
</script>
