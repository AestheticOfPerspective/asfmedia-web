---
const navLinks = [
  { label: 'Start', href: '/' },
  { label: 'Dev Journey', href: '/dev' },
  { label: 'Media', href: '/media' },
  { label: 'Services', href: '/services' },
  { label: 'Kontakt', href: '/contact' },
];

const ecosystem = [
  { label: 'cloud.asfmedia.org', href: 'https://cloud.asfmedia.org' },
  { label: 'JutsuGaming → Twitch', href: 'https://twitch.tv/jutsugaming' },
  { label: 'JutsuGaming → YouTube', href: 'https://youtube.com/@jutsugaming' },
  { label: 'LivePlay', href: 'https://liveplaytv.de' },
  { label: 'LivePlayTV', href: 'https://liveplaytv.de' },
  { label: 'Navidrome', href: '#' },
];
---

<footer class="site-footer">
  <div class="container footer-inner panel">
    <div class="footer-brand">
      <span class="logo">
        <span class="logo-brand">ASF</span><em class="logo-name">media</em>
      </span>
      <p class="footer-tagline">
        Creative Direction · Illustration · Dev · Content.<br />
        Alles unter einer Handschrift. Fossnomade.
      </p>
      <a href="mailto:hello@asfmedia.org">hello@asfmedia.org</a>
    </div>

    <div class="footer-links">
      <h4>Navigation</h4>
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>

    <div class="footer-links">
      <h4>Ecosystem</h4>
      {ecosystem.map((link) => (
        <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel="noopener">{link.label}</a>
      ))}
    </div>

    <div class="footer-meta">
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
      <span>© {new Date().getFullYear()} ASFMedia</span>
    </div>
  </div>
</footer>

<style>
.site-footer {
  padding: 2.6rem 0 2.2rem;
}

.footer-inner {
  padding: 1.6rem;
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr auto;
  gap: 1.4rem;
}

.logo {
  display: inline-flex;
  align-items: baseline;
  gap: 0.1rem;
}

.logo-brand {
  font-family: var(--font-mono);
  font-size: 1.05rem;
  font-weight: 500;
  color: var(--ink);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.logo-name {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-style: italic;
  color: var(--cyan);
  line-height: 1;
}

.footer-tagline {
  margin: 0.8rem 0;
  max-width: 28ch;
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--ink-soft);
}

.footer-brand a {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--cyan);
}

.footer-links {
  display: flex;
  flex-direction: column;
  gap: 0.42rem;
}

.footer-links h4 {
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: 0.72rem;
  color: var(--cyan);
  margin-bottom: 0.3rem;
}

.footer-links a {
  font-size: 0.86rem;
  color: var(--ink-soft);
}

.footer-links a:hover {
  color: var(--amber);
}

.footer-meta {
  display: flex;
  flex-direction: column;
  gap: 0.48rem;
  align-items: flex-start;
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: 0.72rem;
  color: var(--cyan);
}

.footer-meta a {
  font-size: 0.86rem;
  color: var(--ink-soft);
  text-transform: none;
  letter-spacing: 0;
}

.footer-meta a:hover {
  color: var(--amber);
}

.footer-meta span {
  color: var(--ink-muted);
  font-size: 0.82rem;
  text-transform: none;
  letter-spacing: 0;
}

@media (max-width: 980px) {
  .footer-inner {
    grid-template-columns: 1fr 1fr;
  }

  .footer-brand {
    grid-column: 1 / -1;
  }
}

@media (max-width: 640px) {
  .footer-inner {
    grid-template-columns: 1fr;
  }
}
</style>
