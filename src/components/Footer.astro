---
const quickLinks = [
  { label: 'Start', href: '/' },
  { label: 'Module', href: '/module' },
  { label: 'Templates', href: '/templates' },
  { label: 'Projekt', href: '/about' },
  { label: 'Kontakt', href: '/contact' },
];

const projectLinks = [
  { label: 'Session Brief', href: '/about#session-brief' },
  { label: 'Roadmap', href: '/module#roadmap' },
  { label: 'Early Access', href: '/contact#early-access' },
];
---

<footer class="site-footer">
  <div class="container footer-inner panel">
    <div class="footer-brand">
      <span class="logo">ultramind.one</span>
      <p>
        Interaktive Lernreise fuer die 8 Intelligenzraeume nach Gardner.
        Entwickelt als modulares Experience-System.
      </p>
      <a href="mailto:hello@ultramind.one">hello@ultramind.one</a>
    </div>

    <div class="footer-links">
      <h4>Navigieren</h4>
      {quickLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>

    <div class="footer-links">
      <h4>Projekt</h4>
      {projectLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>

    <div class="footer-meta">
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
      <span>© {new Date().getFullYear()} ultramind.one</span>
    </div>
  </div>
</footer>

<style>
.site-footer {
  padding: 2.6rem 0 2.2rem;
}

.footer-inner {
  padding: 1.6rem;
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr auto;
  gap: 1.4rem;
}

.logo {
  font-family: var(--font-display);
  font-size: 1.5rem;
  color: var(--ink);
}

.footer-brand p {
  margin: 0.8rem 0;
  max-width: 28ch;
  font-size: 0.9rem;
  line-height: 1.6;
}

.footer-brand a {
  font-size: 0.9rem;
  font-weight: 700;
}

.footer-links {
  display: flex;
  flex-direction: column;
  gap: 0.42rem;
}

.footer-links h4,
.footer-meta {
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: 0.72rem;
  color: var(--ink-muted);
}

.footer-links a,
.footer-meta a,
.footer-meta span {
  font-size: 0.86rem;
  color: var(--ink-soft);
}

.footer-meta {
  display: flex;
  flex-direction: column;
  gap: 0.48rem;
  align-items: flex-start;
}

@media (max-width: 980px) {
  .footer-inner {
    grid-template-columns: 1fr 1fr;
  }

  .footer-brand {
    grid-column: 1 / -1;
  }
}

@media (max-width: 640px) {
  .footer-inner {
    grid-template-columns: 1fr;
  }
}
</style>
